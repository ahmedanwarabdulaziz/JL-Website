rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Admin-only: same emails as in app (src/lib/constants.ts)
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'ahmedanwarabdulaziz@gmail.com' ||
        request.auth.token.email == 'jl@jlupholstery.com'
      );
    }

    match /tagCategories/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /tags/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /upholsteryPieces/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /projects/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /quotationRequests/{docId} {
      allow create: if true;
      // Allow unauthenticated update only to add image links (once), when service account key cannot be used
      allow update: if isAdmin()
        || (request.auth == null
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['fileUrl', 'fileUrls', 'fileName', 'updatedAt'])
            && !('fileUrls' in resource.data));
      allow read, delete: if isAdmin();
    }
  }
}
